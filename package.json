{
  "name": "polygon-nft-minting",
  "version": "1.0.0",
  "description": "NFT Minting system on Polygon Mumbai — ERC-721 smart contract + Express API",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "compile": "npx hardhat compile",
    "test:contracts": "npx hardhat test PolygonNFT.test.js",
    "test:api": "NODE_ENV=test npx mocha test/api.test.js --timeout 10000",
    "test": "npm run test:contracts && npm run test:api",
    "deploy:mumbai": "npx hardhat run deploy.js --network mumbai",
    "deploy:local": "npx hardhat run deploy.js --network hardhat",
    "node:local": "npx hardhat node",
    "api:start": "node server.js",
    "api:dev": "nodemon server.js",
    "gas-report": "REPORT_GAS=true npx hardhat test test/PolygonNFT.test.js",
    "lint": "npx solhint 'contracts/**/*.sol'",
    "start": "node server.js"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "chai": "^4.3.7",
    "hardhat": "^2.22.0",
    "mocha": "^10.3.0",
    "nodemon": "^3.1.0",
    "sinon": "^17.0.0",
    "solhint": "^4.5.4",
    "supertest": "^6.3.4"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "main": "PolygonNFT.test.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
